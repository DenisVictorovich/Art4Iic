          .equ	ADC2D	= 4	; ADC2 Digital input Disable
          .equ	ADC0D	= 5	; ADC0 Digital input Disable
         
         ; USI
         ; USIBR - USI Buffer Register
         
         ; USIDR - USI Data Register
          .equ	USIDR0	= 0	; USI Data Register bit 0
